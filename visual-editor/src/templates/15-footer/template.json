{
  "id": "footer",
  "name": "Footer",
  "version": 1,
  "tree": [
    {
      "id": "footer-section",
      "type": "section",
      "templateId": "footer",
      "templateName": "Footer",
      "templateCategory": "Footer",
      "templateVersion": 1,
      "styles": {
        "desktop": {
          "padding": "48px 32px",
          "background": "#0a1a2f",
          "color": "#ffffff"
        }
      },
      "children": [
        {
          "id": "footer-logo",
          "type": "image",
          "content": {
            "src": "/images/footer-logo.png",
            "alt": "Valor Wave Entertainment"
          },
          "styles": {
            "desktop": {
              "height": "64px",
              "margin": "0 auto 16px",
              "display": "block"
            }
          }
        },
        {
          "id": "footer-tagline",
          "type": "text",
          "content": { "text": "Honoring Every Moment • Honoring All Heroes" },
          "styles": {
            "desktop": {
              "textAlign": "center",
              "fontSize": "16px",
              "marginBottom": "20px"
            }
          }
        },
        {
          "id": "footer-contact",
          "type": "container",
          "styles": {
            "desktop": {
              "display": "flex",
              "flexDirection": "column",
              "gap": "6px",
              "textAlign": "center",
              "marginBottom": "20px"
            }
          },
          "children": [
            {
              "id": "footer-phone",
              "type": "link",
              "content": {
                "text": "(423) 777-1234",
                "href": "tel:14237771234"
              }
            },
            {
              "id": "footer-email",
              "type": "link",
              "content": {
                "text": "valorwaveentertainment@gmail.com",
                "href": "mailto:valorwaveentertainment@gmail.com"
              }
            },
            {
              "id": "footer-address-line-1",
              "type": "text",
              "content": { "text": "Chattanooga, Tennessee" }
            },
            {
              "id": "footer-address-line-2",
              "type": "text",
              "content": { "text": "Serving Southeast TN & Northwest GA" }
            }
          ]
        },
        {
          "id": "footer-social",
          "type": "container",
          "styles": {
            "desktop": {
              "display": "flex",
              "justifyContent": "center",
              "gap": "16px",
              "marginBottom": "20px"
            }
          },
          "children": [
            {
              "id": "footer-facebook",
              "type": "link",
              "content": {
                "text": "Facebook",
                "href": "https://facebook.com/valorwaveentertainment"
              }
            },
            {
              "id": "footer-instagram",
              "type": "link",
              "content": {
                "text": "Instagram",
                "href": "https://instagram.com/valorwaveentertainment"
              }
            },
            {
              "id": "footer-x",
              "type": "link",
              "content": {
                "text": "X",
                "href": "https://x.com/valorwaveent"
              }
            }
          ]
        },
        {
          "id": "footer-copyright",
          "type": "text",
          "content": {
            "text": "© 2024 Valor Wave Entertainment. All Rights Reserved."
          },
          "styles": {
            "desktop": {
              "textAlign": "center",
              "fontSize": "14px",
              "opacity": "0.8"
            }
          }
        }
      ]
    }
  ]
}