{
  "id": "bio",
  "name": "Bio",
  "version": 1,
  "tree": [
    {
      "id": "bio-section",
      "type": "section",
      "templateId": "bio",
      "templateName": "Bio",
      "templateCategory": "Bio",
      "templateVersion": 1,
      "styles": {
        "desktop": {
          "padding": "64px 40px",
          "background": "#f5f7fa",
          "color": "#0a1a2f"
        }
      },
      "children": [
        {
          "id": "bio-layout",
          "type": "container",
          "styles": {
            "desktop": {
              "display": "grid",
              "gridTemplateColumns": "minmax(0,1fr) minmax(0,1.5fr)",
              "gap": "32px",
              "alignItems": "start"
            }
          },
          "children": [
            {
              "id": "bio-left",
              "type": "container",
              "children": [
                {
                  "id": "bio-image",
                  "type": "image",
                  "content": {
                    "src": "/images/dj-portrait-sam.jpg",
                    "alt": "Sam Massengale – Founder & DJ"
                  },
                  "styles": {
                    "desktop": {
                      "borderRadius": "12px",
                      "width": "100%",
                      "objectFit": "cover"
                    }
                  }
                }
              ]
            },
            {
              "id": "bio-right",
              "type": "container",
              "children": [
                {
                  "id": "bio-heading",
                  "type": "text",
                  "content": { "text": "Meet the DJ" },
                  "styles": {
                    "desktop": {
                      "fontSize": "28px",
                      "fontWeight": "700",
                      "marginBottom": "8px"
                    }
                  }
                },
                {
                  "id": "bio-name",
                  "type": "text",
                  "content": { "text": "Sam Massengale – Founder & DJ" },
                  "styles": {
                    "desktop": {
                      "fontSize": "18px",
                      "fontWeight": "600",
                      "marginBottom": "16px"
                    }
                  }
                },
                {
                  "id": "bio-text-1",
                  "type": "text",
                  "content": {
                    "text": "Hello! My name is <strong>Sam Massengale</strong>, and I’ve proudly called Chattanooga home my entire life. I served over 12 years in the <strong>United States Army</strong> and hold a <strong>Master’s Degree from Belhaven University</strong>. I am blessed with a wonderful wife and four amazing boys."
                  }
                },
                {
                  "id": "bio-text-2",
                  "type": "text",
                  "content": {
                    "text": "Alongside my wife, I decided it was time to turn our passion for <strong>music and singing</strong> into something special — and that’s how <strong>Valor Wave Entertainment</strong> was born. With over 12 years of DJ experience across weddings, corporate events, and community celebrations, I bring professionalism, creativity, and heart to every event."
                  }
                },
                {
                  "id": "bio-text-3",
                  "type": "text",
                  "content": {
                    "text": "Guided by our loving Father and Jesus Christ, our mission is simple: to provide a <strong>worry-free, faith-based, unforgettable experience</strong>. We look forward to honoring every moment — and all heroes — while creating memories that last a lifetime."
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}