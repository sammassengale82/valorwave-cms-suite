{
  "id": "header",
  "name": "Header",
  "version": 1,
  "tree": [
    {
      "id": "header-bar",
      "type": "section",
      "templateId": "header",
      "templateName": "Header",
      "templateCategory": "Header",
      "templateVersion": 1,
      "styles": {
        "desktop": {
          "padding": "12px 32px",
          "background": "#0a1a2f",
          "color": "#ffffff",
          "display": "flex",
          "alignItems": "center",
          "justifyContent": "space-between"
        }
      },
      "children": [
        {
          "id": "header-left",
          "type": "container",
          "styles": {
            "desktop": {
              "display": "flex",
              "alignItems": "center",
              "gap": "12px"
            }
          },
          "children": [
            {
              "id": "header-logo",
              "type": "image",
              "content": {
                "src": "/images/mini-logo.png",
                "alt": "Valor Wave Entertainment"
              },
              "styles": {
                "desktop": {
                  "height": "40px"
                }
              }
            },
            {
              "id": "header-brand-text",
              "type": "text",
              "content": { "text": "Valor Wave Entertainment" },
              "styles": {
                "desktop": {
                  "fontSize": "18px",
                  "fontWeight": "600"
                }
              }
            }
          ]
        },
        {
          "id": "header-nav",
          "type": "container",
          "styles": {
            "desktop": {
              "display": "flex",
              "alignItems": "center",
              "gap": "18px"
            }
          },
          "children": [
            {
              "id": "nav-services",
              "type": "link",
              "content": { "text": "Services", "href": "#services" }
            },
            {
              "id": "nav-availability",
              "type": "link",
              "content": { "text": "Availability", "href": "#calendar" }
            },
            {
              "id": "nav-hero-discount",
              "type": "link",
              "content": { "text": "Hero Discount", "href": "#hero-discount" }
            },
            {
              "id": "nav-request-quote",
              "type": "button",
              "content": {
                "text": "Request a Quote",
                "href": "https://portal.valorwaveentertainment.com/request_information.asp?djidnumber=28542"
              }
            },
            {
              "id": "nav-client-portal",
              "type": "link",
              "content": {
                "text": "Client Portal",
                "href": "https://portal.valorwaveentertainment.com/clientlogon.asp?djidnumber=28542"
              }
            }
          ]
        }
      ]
    }
  ]
}